generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String?   @unique
  password       String
  name           String
  role           String    // ADMIN, STUDENT, FACULTY, HOD
  
  // Student specifics
  rollNumber     String?   @unique
  year           Int?
  batch          String?
  advisorId      String?
  advisor        User?     @relation("AdvisorStudents", fields: [advisorId], references: [id])
  advisedStudents User[]   @relation("AdvisorStudents")

  // Faculty/HOD specifics
  employeeId     String?   @unique
  isActivated    Boolean   @default(true)
  signatureUrl   String?

  requests       Request[] @relation("StudentRequests")
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PreRegisteredStudent {
  id         String   @id @default(uuid())
  rollNumber String   @unique
  registered Boolean  @default(false)
}

model PreRegisteredStaff {
  id          String   @id @default(uuid())
  employeeId  String   @unique
  role        String   // FACULTY, HOD
  isActivated Boolean  @default(false)
}

model Request {
  id              String   @id @default(uuid())
  studentId       String
  student         User     @relation("StudentRequests", fields: [studentId], references: [id])
  
  type            String   // PERMISSION_LETTER, SCHOLARSHIP_FORM, OTHER
  status          String   // PENDING_ADVISOR, PENDING_HOD, APPROVED, REJECTED
  
  documentPath    String
  signedDocPath   String?
  rejectionReason String?
  
  coordinates     SignatureCoordinate[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SignatureCoordinate {
  id        String  @id @default(uuid())
  requestId String
  request   Request @relation(fields: [requestId], references: [id])
  
  role      String  // FACULTY, HOD
  x         Float
  y         Float
}
